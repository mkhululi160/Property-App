{
  "name": "property-app-frontend",
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "REACT_APP_API_URL": "https://property-app-live.onrender.com/api",
    "REACT_APP_GOOGLE_MAPS_API_KEY": "@google_maps_api_key",
    "REACT_APP_STRIPE_PUBLIC_KEY": "@stripe_public_key"
  }
}